{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QR Studio",
  "version": "0.1.0",
  "identifier": "com.rodolfohre.qrstudio",
  "mainBinaryName": "qr-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QR Studio",
        "width": 900,
        "height": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Gerador de QR codes",
    "longDescription": "QR Studio — gerador de QR codes com estilos, cores, gradiente e logo, e exportação PNG/SVG.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
